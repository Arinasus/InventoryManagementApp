@using InventoryManagementApp.Models
@model IEnumerable<UserManagementViewModel>

<h2 class="mb-4">Управление пользователями</h2>

<table class="table table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>
                <a href="?sortOrder=@ViewData["EmailSort"]" class="text-white text-decoration-none">
                    Email
                </a>
            </th>

            <th>
                <a href="?sortOrder=@ViewData["RoleSort"]" class="text-white text-decoration-none">
                    Роль
                </a>
            </th>

            <th>
                <a href="?sortOrder=@ViewData["StatusSort"]" class="text-white text-decoration-none">
                    Статус
                </a>
            </th>

            <th>
                <a href="?sortOrder=@ViewData["InvSort"]" class="text-white text-decoration-none">
                    Инвентари
                </a>
            </th>

            <th>
                <a href="?sortOrder=@ViewData["PostsSort"]" class="text-white text-decoration-none">
                    Посты
                </a>
            </th>

            <th>
                <a href="?sortOrder=@ViewData["CreatedSort"]" class="text-white text-decoration-none">
                    Создан
                </a>
            </th>

            <th>Последний вход</th>
            <th class="text-end">Действия</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>

                <td>
                    @if (user.IsAdmin)
                    {
                        <span class="badge bg-success">Admin</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">User</span>
                    }
                </td>

                <td>
                    @if (user.IsBlocked)
                    {
                        <span class="badge bg-danger">Заблокирован</span>
                    }
                    else
                    {
                        <span class="badge bg-primary">Активен</span>
                    }
                </td>

                <td>@user.InventoriesCount</td>
                <td>@user.PostsCount</td>

                <td>@user.CreatedAt.ToShortDateString()</td>
                <td>@(user.LastLogin?.ToString("g") ?? "—")</td>

                <td class="text-end">
                    @if (!user.IsAdmin)
                    {
                        <a href="/Admin/MakeAdmin/@user.Id" class="btn btn-sm btn-outline-success me-1">
                            <i class="bi bi-shield-lock"></i>
                        </a>
                    }
                    else
                    {
                        <a href="/Admin/RemoveAdmin/@user.Id" class="btn btn-sm btn-outline-warning me-1">
                            <i class="bi bi-shield-slash"></i>
                        </a>
                    }

                    @if (!user.IsBlocked)
                    {
                        <a href="/Admin/Block/@user.Id" class="btn btn-sm btn-outline-danger me-1">
                            <i class="bi bi-person-x"></i>
                        </a>
                    }
                    else
                    {
                        <a href="/Admin/Unblock/@user.Id" class="btn btn-sm btn-outline-primary me-1">
                            <i class="bi bi-person-check"></i>
                        </a>
                    }

                    <a href="/Admin/Delete/@user.Id" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
