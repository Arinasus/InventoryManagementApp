@using InventoryManagementApp.Models
@model HomePageViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<div class="container mt-4">
    <form method="get" class="mb-4">
        <input type="text" name="search" value="@Model.SearchQuery"
               class="form-control form-control-lg"
               placeholder="@Localizer["SearchPlaceholder"]" />
    </form>

    <h3 class="mb-3">@Localizer["LatestInventories"]</h3>
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Localizer["Title"]</th>
                <th>@Localizer["Description"]</th>
                <th>@Localizer["Creator"]</th>
                <th>@Localizer["ItemsCount"]</th>
                <th>@Localizer["CreatedAt"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var inv in Model.LatestInventories)
            {
                <tr onclick="location.href='/Inventory/Details/@inv.Id'" style="cursor:pointer;">
                    <td>@inv.Title</td>
                    <td>@inv.Description</td>
                    <td>@inv.CreatorName</td>
                    <td>@inv.ItemsCount</td>
                    <td>@inv.CreatedAt.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>

    <h3 class="mt-5 mb-3">@Localizer["PopularInventories"]</h3>
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Localizer["Title"]</th>
                <th>@Localizer["Description"]</th>
                <th>@Localizer["Creator"]</th>
                <th>@Localizer["ItemsCount"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var inv in Model.PopularInventories)
            {
                <tr onclick="location.href='/Inventory/Details/@inv.Id'" style="cursor:pointer;">
                    <td>@inv.Title</td>
                    <td>@inv.Description</td>
                    <td>@inv.CreatorName</td>
                    <td>@inv.ItemsCount</td>
                </tr>
            }
        </tbody>
    </table>

    <h3 class="mt-5 mb-3">@Localizer["Tags"]</h3>
    <div>
        @foreach (var tag in Model.Tags)
        {
            <a href="/Search?tag=@tag.Name"
               class="badge bg-primary text-white me-2 mb-2"
               style="font-size: 1.1rem;">
                @tag.Name (@tag.Count)
            </a>
        }
    </div>
</div>
