@model AddItemViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<div class="container mt-4">
    <h2>@Localizer["AddItem"].Value</h2>

    <form asp-action="AddItem" method="post">
        <input type="hidden" asp-for="InventoryId" />

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        @if (Model.Fields == null || !Model.Fields.Any())
        {
            <p class="text-muted">@Localizer["NoCustomFields"].Value</p>
        }
        else
        {
            @foreach (var field in Model.Fields)
            {
                <div class="mb-3">
                    <label class="form-label">@field.Title</label>

                    @if (!string.IsNullOrEmpty(field.Description))
                    {
                        <div class="form-text">@field.Description</div>
                    }

                    @switch ((InventoryManagementApp.Models.FieldType)field.Type)
                    {
                        case FieldType.SingleLineText:
                            <input class="form-control" name="Values[@field.Id]" />
                            break;

                        case FieldType.MultiLineText:
                            <textarea class="form-control" name="Values[@field.Id]" rows="3"></textarea>
                            break;

                        case FieldType.Number:
                            <input class="form-control" type="number" name="Values[@field.Id]" />
                            break;

                        case FieldType.DocumentLink:
                            <input class="form-control" type="url" name="Values[@field.Id]" />
                            break;

                        case FieldType.Boolean:
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="true" name="Values[@field.Id]" />
                                <label class="form-check-label">@Localizer["Yes"].Value</label>
                            </div>
                            break;

                        default:
                            <input class="form-control" name="Values[@field.Id]" />
                            break;
                    }

                    <span class="text-danger">@Html.ValidationMessage($"Values[{field.Id}]")</span>
                </div>
            }
        }

        <button type="submit" class="btn btn-primary">@Localizer["CreateItem"].Value</button>
        <a href="/Inventory/Details/@Model.InventoryId" class="btn btn-secondary">@Localizer["Cancel"].Value</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
