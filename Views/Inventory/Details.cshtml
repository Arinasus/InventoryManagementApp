@using InventoryManagementApp.Services
@model InventoryDetailsViewModel
@inject IInventoryAccessService Access
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    int invId = Model.Inventory.Id;

    bool canEditInventory = await Access.CanEditInventory(invId, User);
    bool canEditItems = await Access.CanEditItems(invId, User);
}

<div class="container mt-4">

    <ul class="nav nav-tabs mt-4" id="inventoryTabs">
        <li class="nav-item">
            <a class="nav-link active" href="#items" data-bs-toggle="tab">@Localizer["TabItems"]</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#discussion" data-bs-toggle="tab">@Localizer["TabDiscussion"]</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#stats" data-bs-toggle="tab">@Localizer["TabStats"]</a>
        </li>

        @if (canEditInventory)
        {
            <li class="nav-item"><a class="nav-link" href="#settings" data-bs-toggle="tab">@Localizer["TabSettings"]</a></li>
            <li class="nav-item"><a class="nav-link" href="#customid" data-bs-toggle="tab">@Localizer["TabCustomId"]</a></li>
            <li class="nav-item"><a class="nav-link" href="#fields" data-bs-toggle="tab">@Localizer["TabFields"]</a></li>
            <li class="nav-item"><a class="nav-link" href="#access" data-bs-toggle="tab">@Localizer["TabAccess"]</a></li>
        }
    </ul>


    <div class="tab-content mt-3">

        <div class="tab-pane fade show active" id="items">
            @await Html.PartialAsync("_TabItems", Model.Items)
        </div>
        <div class="tab-pane fade" id="fields">
            @await Html.PartialAsync("_TabFields", Model.Fields)
        </div>
        <div class="tab-pane fade" id="customid">
            @await Html.PartialAsync("_TabCustomId", Model.CustomId)
        </div>
       <div class="tab-pane fade" id="discussion">
            @await Html.PartialAsync("_TabDiscussion", Model.Discussion)
        </div>

        <div class="tab-pane fade" id="settings">
            @await Html.PartialAsync("_TabSettings", Model.Settings)
        </div>

        <div class="tab-pane fade" id="access">
            @await Html.PartialAsync("_TabAccess", Model.Access)
        </div>
        
        <div class="tab-pane fade" id="stats">
            @await Html.PartialAsync("_TabStats", Model.Stats)
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/inventory-autosave.js"></script>
    
    <script>
        const searchInput = document.getElementById("user-search");
        const results = document.getElementById("user-results");
        const selectedUser = document.getElementById("selected-user-id");
        const form = document.getElementById("add-access-form");

        let timer = null;

        searchInput.addEventListener("input", () => {
            clearTimeout(timer);
            const q = searchInput.value.trim();
            if (q.length < 2) {
                results.innerHTML = "";
                return;
            }

            timer = setTimeout(() => {
                fetch(`/Inventory/SearchUsers?query=${encodeURIComponent(q)}`)
                    .then(r => r.json())
                    .then(list => {
                        results.innerHTML = "";
                        list.forEach(u => {
                            const item = document.createElement("button");
                            item.type = "button";
                            item.className = "list-group-item list-group-item-action";
                            item.textContent = `${u.userName} (${u.email})`;
                            item.onclick = () => {
                                selectedUser.value = u.id;
                                form.submit();
                            };
                            results.appendChild(item);
                        });
                    });
            }, 300);
        });

        const table = document.getElementById("access-table").querySelector("tbody");

        function sortTable(selector) {
            const rows = Array.from(table.querySelectorAll("tr"));

            rows.sort((a, b) => {
                const A = a.querySelector(selector).innerText.toLowerCase();
                const B = b.querySelector(selector).innerText.toLowerCase();
                return A.localeCompare(B);
            });

            rows.forEach(r => table.appendChild(r));
        }

        document.getElementById("sort-name").addEventListener("click", () => {
            sortTable(".col-name");
        });

        document.getElementById("sort-email").addEventListener("click", () => {
            sortTable(".col-email");
        });
    </script>

}

