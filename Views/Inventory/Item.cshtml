@using InventoryManagementApp.Model
@model EditItemViewModel

<div class="container mt-4">
    <h2>Редактировать предмет</h2>

    <form asp-action="EditItem" method="post">
        <input type="hidden" asp-for="ItemId" />
        <input type="hidden" asp-for="InventoryId" />

        @foreach (var field in Model.Fields)
        {
            <div class="mb-3">
                <label class="form-label">@field.Title</label>

                @switch (field.Type)
                {
                    case FieldType.SingleLineText:
                        <input class="form-control"
                               name="Values[@field.Id]"
                               value="@Model.Values[field.Id]" />
                        break;

                    case FieldType.MultiLineText:
                        <textarea class="form-control"
                      name="Values[@field.Id]"
                      rows="3">@Model.Values[field.Id]</textarea>
                        break;

                    case FieldType.Number:
                        <input class="form-control"
                               type="number"
                               name="Values[@field.Id]"
                               value="@Model.Values[field.Id]" />
                        break;

                    case FieldType.DocumentLink:
                        <input class="form-control"
                               type="url"
                               name="Values[@field.Id]"
                               value="@Model.Values[field.Id]" />
                        break;

                    case FieldType.Boolean:
                        var isChecked = Model.Values[field.Id] == "true";
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="Values[@field.Id]"
                                   value="true"
                                   @(isChecked ? "checked" : "") />
                            <label class="form-check-label">Да</label>
                        </div>
                        break;
                }
            </div>
        }

        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a href="/Inventory/Details/@Model.InventoryId" class="btn btn-secondary">Назад</a>
    </form>
</div>
