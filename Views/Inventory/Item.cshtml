@using InventoryManagementApp.Model
@model InventoryItem

<div class="container mt-4">

    <h2>Предмет @Model.CustomId</h2>

    <div class="card mt-3">
        <div class="card-body">

            <h5 class="card-title">Основная информация</h5>

            <p><strong>ID:</strong> @Model.Id</p>
            <p><strong>Custom ID:</strong> @Model.CustomId</p>
            <p><strong>Создан:</strong> @Model.CreatedAt.ToLocalTime()</p>
            <p><strong>Обновлён:</strong> @Model.UpdatedAt.ToLocalTime()</p>
            <p><strong>Лайков:</strong> @Model.Likes?.Count ?? 0</p>

            <hr />

            <h5 class="card-title">Поля</h5>

            @if (Model.FieldValues != null && Model.FieldValues.Any())
            {
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Поле</th>
                            <th>Значение</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fv in Model.FieldValues)
                        {
                            <tr>
                                <td>@fv.Field?.Title</td>
                                <td>@fv.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">Нет заполненных полей.</p>
            }

            <hr />

            <div class="mt-3">
                <a class="btn btn-secondary" href="/Inventory/Details/@Model.InventoryId">Назад к инвентарю</a>
                <a class="btn btn-warning disabled">Редактировать (пока не работает)</a>
                <a class="btn btn-danger disabled">Удалить (пока не работает)</a>
            </div>

        </div>
    </div>

</div>
