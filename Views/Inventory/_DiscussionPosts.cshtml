@model InventoryDiscussionViewModel
@using Markdig

@{
    var pipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
}

@if (!Model.Posts.Any())
{
    <p class="text-muted">Пока нет сообщений.</p>
}
else
{
    <ul class="list-group">
        @foreach (var p in Model.Posts)
        {
            <li class="list-group-item">
                <div class="d-flex justify-content-between">
                    <div>
                        <a href="/User/Profile/@p.UserId">
                            @p.User.UserName
                        </a>
                        <span class="text-muted small">
                            @p.CreatedAt.ToLocalTime().ToString("g")
                        </span>
                    </div>
                </div>

                <div class="mt-2">
                    @Html.Raw(Markdown.ToHtml(p.Content ?? "", pipeline))
                </div>
            </li>
        }
    </ul>
}
