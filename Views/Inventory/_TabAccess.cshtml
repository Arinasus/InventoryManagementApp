@model InventoryAccessViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<h4>@Localizer["AccessManagement"].Value</h4>

<div class="mb-3">
    <label class="form-label">@Localizer["AddUser"].Value</label>
    <input id="user-search" class="form-control" placeholder="@Localizer["SearchUserPlaceholder"].Value" />
    <div id="user-results" class="list-group mt-1"></div>
</div>

<form id="add-access-form" method="post" action="/Inventory/AddAccess">
    <input type="hidden" name="inventoryId" value="@Model.InventoryId" />
    <input type="hidden" id="selected-user-id" name="userId" />
</form>

<hr />

<h5 class="d-flex justify-content-between align-items-center">
    <span>@Localizer["UsersWithAccess"].Value</span>

    <div class="btn-group">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="sort-name">
            @Localizer["SortByName"].Value
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="sort-email">
            @Localizer["SortByEmail"].Value
        </button>
    </div>
</h5>

<table class="table table-striped" id="access-table">
    <thead>
        <tr>
            <th>@Localizer["Name"].Value</th>
            <th>Email</th>
            <th>@Localizer["GrantedAt"].Value</th>
            <th>@Localizer["AccessLevel"].Value</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model.AccessList)
        {
            <tr class="access-row">
                <td class="col-name">@a.User.UserName</td>
                <td class="col-email">@a.User.Email</td>
                <td>@a.GrantedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@Localizer["WriteAccess"].Value</td>

                <td class="text-end">
                    <div class="actions" style="display:none;">
                        <form method="post" action="/Inventory/RemoveAccess/@a.Id" class="d-inline">
                            <input type="hidden" name="inventoryId" value="@Model.InventoryId" />
                            <a href="#" onclick="this.closest('form').submit(); return false;" class="text-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
    .access-row .actions {
        display: none;
    }

    .access-row:hover .actions {
        display: inline-block;
    }
</style>

@section Scripts {
}
