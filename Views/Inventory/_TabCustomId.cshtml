@model InventoryCustomIdViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@functions {
    public string GetPopoverText(InventoryCustomIdPart part)
    {
        return part.Type switch
        {
            CustomIdPartType.FixedText =>
                Localizer["FixedTextDescription"].Value,

            CustomIdPartType.Random20Bit =>
                Localizer["Random20BitDescription"].Value,

            CustomIdPartType.Random32Bit =>
                Localizer["Random32BitDescription"].Value,

            CustomIdPartType.Random6Digits =>
                Localizer["Random6DigitsDescription"].Value,

            CustomIdPartType.Random9Digits =>
                Localizer["Random9DigitsDescription"].Value,

            CustomIdPartType.Guid =>
                Localizer["GuidDescription"].Value,

            CustomIdPartType.DateTime =>
                Localizer["DateTimeDescription"].Value,

            CustomIdPartType.Sequence =>
                Localizer["SequenceDescription"].Value,

            _ => Localizer["DefaultDescription"].Value
        };
    }
}

<h4>@Localizer["CustomId"]</h4>

<div class="alert alert-info">
    @Localizer["Example"]: <strong>@Model.Preview</strong>
</div>

<h5>@Localizer["IdParts"]</h5>

<ul id="id-parts" class="list-group mb-3">
    @foreach (var part in Model.Parts)
    {
        <li class="list-group-item" data-id="@part.Id">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <span class="handle me-2">☰</span>
                    <strong>@part.Type</strong>

                    <i class="bi bi-question-circle ms-2 text-primary"
                       tabindex="0"
                       data-bs-toggle="popover"
                       data-bs-trigger="focus"
                       data-bs-placement="right"
                       data-bs-title="@Localizer["Description"]"
                       data-bs-content="@GetPopoverText(part)">
                    </i>

                    @if (part.Type == CustomIdPartType.FixedText)
                    {
                        <span class="text-muted">(@part.Value)</span>
                    }

                    @if (part.Type == CustomIdPartType.Sequence)
                    {
                        <form method="post" action="/Inventory/UpdatePadding" class="d-inline ms-3">
                            <input type="hidden" name="id" value="@part.Id" />
                            <input type="hidden" name="inventoryId" value="@Model.InventoryId" />

                            <input type="number"
                                   name="padding"
                                   min="1"
                                   max="20"
                                   value="@(part.Padding ?? 4)"
                                   class="form-control form-control-sm d-inline-block"
                                   style="width:80px;"
                                   title="@Localizer["Padding"]" />
                        </form>
                    }
                </div>
            </div>
        </li>
    }
</ul>

<div id="delete-zone"
     class="border border-danger text-center p-3 mb-3 rounded"
     style="background:#ffe5e5;">
    @Localizer["DragToDelete"]
</div>

<h5>@Localizer["AddPart"]</h5>

<form method="post" action="/Inventory/AddCustomIdPart">
    <input type="hidden" name="inventoryId" value="@Model.InventoryId" />

    <select name="type" class="form-select mb-2">
        <option value="FixedText">@Localizer["FixedText"]</option>
        <option value="Random20Bit">@Localizer["Random20Bit"]</option>
        <option value="Random32Bit">@Localizer["Random32Bit"]</option>
        <option value="Random6Digits">@Localizer["Random6Digits"]</option>
        <option value="Random9Digits">@Localizer["Random9Digits"]</option>
        <option value="Guid">@Localizer["Guid"]</option>
        <option value="DateTime">@Localizer["DateTime"]</option>
        <option value="Sequence">@Localizer["Sequence"]</option>
    </select>

    <button class="btn btn-primary">@Localizer["Add"]</button>
</form>
