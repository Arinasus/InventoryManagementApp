@model InventoryCustomIdViewModel

@functions {
    public string GetPopoverText(InventoryCustomIdPart part)
    {
        return part.Type switch
        {
            CustomIdPartType.FixedText =>
                "Фиксированный текст — неизменяемая часть ID. Например: 'INV', 'PC'.",

            CustomIdPartType.Random20Bit =>
                "20‑битное случайное число. Диапазон: 0–1 048 575.",

            CustomIdPartType.Random32Bit =>
                "32‑битное случайное число. Диапазон: 0–4 294 967 295.",

            CustomIdPartType.Random6Digits =>
                "Случайное число из 6 цифр. Форматируется с ведущими нулями.",

            CustomIdPartType.Random9Digits =>
                "Случайное число из 9 цифр. Форматируется с ведущими нулями.",

            CustomIdPartType.Guid =>
                "Глобально уникальный идентификатор (GUID).",

            CustomIdPartType.DateTime =>
                "Текущая дата и время в формате yyyyMMddHHmmss.",

            CustomIdPartType.Sequence =>
                "Последовательность — увеличивающееся число. Можно задать длину (например: 0001).",

            _ => "Элемент ID."
        };
    }
}

<h4>Пользовательский ID</h4>

<div class="alert alert-info">
    Пример: <strong>@Model.Preview</strong>
</div>

<h5>Элементы ID</h5>

<ul id="id-parts" class="list-group mb-3">
    @foreach (var part in Model.Parts)
    {
        <li class="list-group-item"
            data-id="@part.Id">

            <div class="d-flex justify-content-between align-items-center">

                <div>
                    <span class="handle me-2">☰</span>
                    <strong>@part.Type</strong>

                    <i class="bi bi-question-circle ms-2 text-primary"
                       tabindex="0"
                       data-bs-toggle="popover"
                       data-bs-trigger="focus"
                       data-bs-placement="right"
                       data-bs-title="Описание"
                       data-bs-content="@GetPopoverText(part)">
                    </i>

                    @if (part.Type == CustomIdPartType.FixedText)
                    {
                        <span class="text-muted">(@part.Value)</span>
                    }

                    @if (part.Type == CustomIdPartType.Sequence)
                    {
                        <form method="post" action="/Inventory/UpdatePadding" class="d-inline ms-3">
                            <input type="hidden" name="id" value="@part.Id" />
                            <input type="hidden" name="inventoryId" value="@Model.InventoryId" />

                            <input type="number"
                                   name="padding"
                                   min="1"
                                   max="20"
                                   value="@(part.Padding ?? 4)"
                                   class="form-control form-control-sm d-inline-block"
                                   style="width:80px;"
                                   title="Количество цифр" />
                        </form>
                    }
                </div>

            </div>

        </li>
    }
</ul>

<div id="delete-zone"
     class="border border-danger text-center p-3 mb-3 rounded"
     style="background:#ffe5e5;">
    Перетащите элемент сюда, чтобы удалить
</div>

<h5>Добавить элемент</h5>

<form method="post" action="/Inventory/AddCustomIdPart">
    <input type="hidden" name="inventoryId" value="@Model.InventoryId" />

    <select name="type" class="form-select mb-2">
        <option value="FixedText">Фиксированный текст</option>
        <option value="Random20Bit">20‑битное случайное число</option>
        <option value="Random32Bit">32‑битное случайное число</option>
        <option value="Random6Digits">6 цифр</option>
        <option value="Random9Digits">9 цифр</option>
        <option value="Guid">GUID</option>
        <option value="DateTime">Дата/время</option>
        <option value="Sequence">Последовательность</option>
    </select>

    <button class="btn btn-primary">Добавить</button>
</form>

<style>
    .handle {
        cursor: grab;
        font-size: 18px;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll('[data-bs-toggle="popover"]').forEach(el => {
            new bootstrap.Popover(el);
        });

        const idPartsList = document.getElementById('id-parts');
        const deleteZone = document.getElementById('delete-zone');

        if (idPartsList) {
            new Sortable(idPartsList, {
                animation: 150,
                handle: '.handle',
                group: { name: 'idparts', pull: true, put: false },

                onEnd: function (evt) {

                    if (evt.to === deleteZone) {
                        const id = evt.item.dataset.id;

                        fetch(`/Inventory/DeleteCustomIdPart/${id}?inventoryId=@Model.InventoryId`, {
                            method: 'POST'
                        }).then(() => evt.item.remove());

                        return;
                    }

                    const ids = [...idPartsList.querySelectorAll('li')].map(li => parseInt(li.dataset.id));

                    fetch('/Inventory/ReorderCustomIdParts', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(ids)
                    });
                }
            });
        }

        if (deleteZone) {
            new Sortable(deleteZone, {
                group: { name: 'idparts', pull: false, put: true }
            });
        }
    });
</script>
