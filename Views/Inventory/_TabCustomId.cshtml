@using Microsoft.AspNetCore.Mvc.Localization
@model InventoryCustomIdViewModel
@inject IViewLocalizer Localizer

<h4>@Localizer["CustomId"].Value</h4>

<div class="alert alert-info">
    @Localizer["Example"].Value: <strong>@Model.Preview</strong>
</div>

<h5>@Localizer["IdParts"].Value</h5>

<ul id="id-parts" class="list-group mb-3">
    @foreach (var part in Model.Parts)
    {
        var descKey = part.Type switch
        {
            CustomIdPartType.FixedText => "FixedTextDescription",
            CustomIdPartType.Random20Bit => "Random20BitDescription",
            CustomIdPartType.Random32Bit => "Random32BitDescription",
            CustomIdPartType.Random6Digits => "Random6DigitsDescription",
            CustomIdPartType.Random9Digits => "Random9DigitsDescription",
            CustomIdPartType.Guid => "GuidDescription",
            CustomIdPartType.DateTime => "DateTimeDescription",
            CustomIdPartType.Sequence => "SequenceDescription",
            _ => "DefaultDescription"
        };

        <li class="list-group-item" data-id="@part.Id">
            <div class="d-flex justify-content-between align-items-center">

                <div>
                    <span class="handle me-2">☰</span>
                    <strong>@part.Type</strong>

                    <i class="bi bi-question-circle ms-2 text-primary"
                       tabindex="0"
                       data-bs-toggle="popover"
                       data-bs-trigger="focus"
                       data-bs-placement="right"
                       data-bs-title="@Localizer["Description"].Value"
                       data-bs-content="@Localizer[descKey].Value">
                    </i>

                    @if (part.Type == CustomIdPartType.FixedText)
                    {
                        <span class="text-muted">(@part.Value)</span>
                    }

                    @if (part.Type == CustomIdPartType.Sequence)
                    {
                        <form method="post" action="/Inventory/UpdatePadding" class="d-inline ms-3">
                            <input type="hidden" name="id" value="@part.Id" />
                            <input type="hidden" name="inventoryId" value="@Model.InventoryId" />

                            <input type="number"
                                   name="padding"
                                   min="1"
                                   max="20"
                                   value="@(part.Padding ?? 4)"
                                   class="form-control form-control-sm d-inline-block"
                                   style="width:80px;"
                                   title="@Localizer["Padding"].Value" />
                        </form>
                    }
                </div>

            </div>
        </li>
    }
</ul>

<div id="delete-zone"
     class="border border-danger text-center p-3 mb-3 rounded"
     style="background:#ffe5e5;">
    @Localizer["DragToDelete"].Value
</div>

<h5>@Localizer["AddPart"].Value</h5>

<form method="post" action="/Inventory/AddCustomIdPart">
    <input type="hidden" name="inventoryId" value="@Model.InventoryId" />

    <select name="type" class="form-select mb-2">
        <option value="FixedText">@Localizer["FixedText"].Value</option>
        <option value="Random20Bit">@Localizer["Random20Bit"].Value</option>
        <option value="Random32Bit">@Localizer["Random32Bit"].Value</option>
        <option value="Random6Digits">@Localizer["Random6Digits"].Value</option>
        <option value="Random9Digits">@Localizer["Random9Digits"].Value</option>
        <option value="Guid">@Localizer["Guid"].Value</option>
        <option value="DateTime">@Localizer["DateTime"].Value</option>
        <option value="Sequence">@Localizer["Sequence"].Value</option>
    </select>

    <button class="btn btn-primary">@Localizer["Add"].Value</button>
</form>

<style>
    .handle {
        cursor: grab;
        font-size: 18px;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll('[data-bs-toggle="popover"]').forEach(el => {
            new bootstrap.Popover(el);
        });

        const idPartsList = document.getElementById('id-parts');
        const deleteZone = document.getElementById('delete-zone');

        if (idPartsList) {
            new Sortable(idPartsList, {
                animation: 150,
                handle: '.handle',
                group: { name: 'idparts', pull: true, put: false },

                onEnd: function (evt) {

                    if (evt.to === deleteZone) {
                        const id = evt.item.dataset.id;

                        fetch(`/Inventory/DeleteCustomIdPart/${id}?inventoryId=@Model.InventoryId`, {
                            method: 'POST'
                        }).then(() => evt.item.remove());

                        return;
                    }

                    const ids = [...idPartsList.querySelectorAll('li')].map(li => parseInt(li.dataset.id));

                    fetch('/Inventory/ReorderCustomIdParts', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(ids)
                    });
                }
            });
        }

        if (deleteZone) {
            new Sortable(deleteZone, {
                group: { name: 'idparts', pull: false, put: true }
            });
        }
    });
</script>
