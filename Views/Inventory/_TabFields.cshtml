@model InventoryFieldsViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Поля инвентаря</h4>

    <a class="btn btn-primary" href="/Inventory/AddField/@Model.InventoryId">
        + Добавить поле
    </a>
</div>

@if (Model.Fields == null || !Model.Fields.Any())
{
    <p class="text-muted">Пока нет ни одного поля.</p>
}
else
{
    <ul id="fields-list" class="list-group">
        @foreach (var field in Model.Fields)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center"
                data-id="@field.Id">

                <div>
                    <span class="handle me-2">☰</span>
                    <strong>@field.Title</strong>
                    <span class="text-muted">(@field.Type)</span>
                </div>

                <div class="d-flex align-items-center">

                    <form method="post" action="/Inventory/ToggleShowInTable/@field.Id" class="me-3">
                        <input type="hidden" name="inventoryId" value="@Model.InventoryId" />
                        <input type="checkbox"
                               onchange="this.form.submit()"
                               @(field.ShowInTable ? "checked" : "") />
                    </form>

                    <a href="/Inventory/DeleteField/@field.Id?inventoryId=@Model.InventoryId"
                       class="btn btn-sm btn-danger">
                        Удалить
                    </a>
                </div>
            </li>
        }
    </ul>
}

<style>
    .handle {
        cursor: grab;
        font-size: 18px;
    }

    #fields-list .list-group-item {
        user-select: none;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<script>
    const list = document.getElementById('fields-list');
    if (list) {
    new Sortable(list, {
        animation: 150,
        handle: '.handle',
        onEnd: function () {
            const ids = [...list.querySelectorAll('li')].map(li => parseInt(li.dataset.id));

            fetch('/Inventory/ReorderFields', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(ids)
            });
        }
    });
    }
</script>
