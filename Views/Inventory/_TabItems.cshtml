@using InventoryManagementApp.Models
@using Microsoft.AspNetCore.Mvc.Localization
@model InventoryItemsViewModel
@inject IViewLocalizer Localizer

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>@Localizer["Items"].Value</h4>

    <a href="/Inventory/AddItem/@Model.InventoryId" class="btn btn-primary">
        @Localizer["AddItem"].Value
    </a>
</div>

@if (Model.Items == null || !Model.Items.Any())
{
    <p class="text-muted">@Localizer["NoItems"].Value</p>
}
else
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Custom ID</th>
                <th>@Localizer["Created"].Value</th>

                @foreach (var field in Model.TableFields)
                {
                    <th>@field.Title</th>
                }

                <th>@Localizer["Likes"].Value</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr class="item-row" onclick="location.href='/Inventory/Item/@item.Id'">
                    <td>@item.Id</td>
                    <td>@item.CustomId</td>
                    <td>@item.CreatedAt.ToLocalTime()</td>

                    @foreach (var field in Model.TableFields)
                    {
                        <td>@item.FieldValues[field.Title]</td>
                    }

                    <td>
                        <button class="btn btn-sm btn-outline-danger like-btn"
                                data-id="@item.Id"
                                onclick="event.stopPropagation();">
                            <i class="bi bi-heart-fill"></i>
                            <span class="like-count">@item.Likes</span>
                        </button>
                    </td>

                    <td class="text-end">
                        <div class="actions" style="display:none;">
                            <a href="/Inventory/DeleteItem/@item.Id" class="text-danger me-2">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<style>
    .item-row .actions {
        display: none;
    }

    .item-row:hover .actions {
        display: inline-block;
    }

    .like-btn i {
        transition: transform 0.15s ease, color 0.15s ease;
    }

    .like-btn:hover i {
        transform: scale(1.2);
        color: #dc3545;
    }
</style>

<script>
    document.querySelectorAll(".item-row").forEach(row => {
        row.addEventListener("mouseenter", () => {
            row.querySelector(".actions").style.display = "inline-block";
        });
        row.addEventListener("mouseleave", () => {
            row.querySelector(".actions").style.display = "none";
        });
    });

    document.querySelectorAll(".like-btn").forEach(btn => {
        btn.addEventListener("click", () => {
            const id = btn.dataset.id;

            fetch(`/InventoryItem/ToggleLike?itemId=${id}`, {
                method: "POST",
                headers: { "X-Requested-With": "XMLHttpRequest" }
            })
            .then(r => r.json())
            .then(data => {
                btn.querySelector(".like-count").innerText = data.likes;
            });
        });
    });
</script>
