@using InventoryManagementApp.Models
@model InventoryItemsViewModel

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Предметы</h4>

    <a href="/Inventory/AddItem/@Model.InventoryId" class="btn btn-primary">
        Добавить предмет
    </a>
</div>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            @foreach (var field in Model.TableFields)
            {
                <th>@field.Title</th>
            }
            <th>Лайки</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr class="item-row" onclick="location.href='/Inventory/Item/@item.Id'">
                <td>@item.CustomId</td>

                @foreach (var field in Model.TableFields)
                {
                    <td>@item.FieldValues[field.Title]</td>
                }

                <td>@item.Likes</td>

                <td class="text-end">
                    <div class="actions" style="display:none;">
                        <a href="/Inventory/DeleteItem/@item.Id" class="text-danger me-2">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    document.querySelectorAll(".item-row").forEach(row => {
        row.addEventListener("mouseenter", () => {
            row.querySelector(".actions").style.display = "inline-block";
        });
        row.addEventListener("mouseleave", () => {
            row.querySelector(".actions").style.display = "none";
        });
    });
</script>
