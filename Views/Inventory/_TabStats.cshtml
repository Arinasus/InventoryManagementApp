@model InventoryStatsViewModel

<h4>Общая статистика</h4>

<ul class="list-group mb-4">
    <li class="list-group-item d-flex justify-content-between">
        <span>Количество предметов</span>
        <strong>@Model.TotalItems</strong>
    </li>
    <li class="list-group-item d-flex justify-content-between">
        <span>Количество лайков</span>
        <strong>@Model.TotalLikes</strong>
    </li>
    <li class="list-group-item d-flex justify-content-between">
        <span>Количество сообщений в обсуждении</span>
        <strong>@Model.TotalPosts</strong>
    </li>
</ul>

@if (Model.AverageNumericFields.Any())
{
    <h5>Средние значения числовых полей</h5>
    <ul class="list-group mb-4">
        @foreach (var kv in Model.AverageNumericFields)
        {
            <li class="list-group-item d-flex justify-content-between">
                <span>@kv.Key</span>
                <strong>@kv.Value.ToString("0.##")</strong>
            </li>
        }
    </ul>
}

@if (Model.MostCommonStringFields.Any())
{
    <h5>Частые значения текстовых полей</h5>
    <ul class="list-group">
        @foreach (var kv in Model.MostCommonStringFields)
        {
            <li class="list-group-item d-flex justify-content-between">
                <span>@kv.Key</span>
                <strong>@kv.Value</strong>
            </li>
        }
    </ul>
}

