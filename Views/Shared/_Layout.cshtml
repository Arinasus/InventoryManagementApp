@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@RenderSection("Styles", required: false)

@{
    var culture = Context.Features
        .Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>()?
        .RequestCulture.Culture.TwoLetterISOLanguageName ?? "ru";

    var theme = Context.Request.Cookies["theme"] ?? "light";
}

<!DOCTYPE html>
<html lang="@culture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InventoryManagerApp</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/site-@(theme).css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="@Html.Raw("https://cdn.jsdelivr.net/npm/@yaireo/tagify/dist/tagify.css")">
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    InventoryManagerApp
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <ul class="navbar-nav me-auto mb-2 mb-sm-0">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                @Localizer["Home"]
                            </a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Admin">
                                    @Localizer["AdminPanel"]
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" href="/Inventory/Index">
                                @Localizer["Inventories"]
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Inventory/Create">
                                @Localizer["CreateInventory"]
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/User/Profile">
                                @Localizer["Profile"]
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">

                        <form method="post" action="/Theme/SetTheme">
                            <select name="theme" onchange="this.form.submit()" class="form-select form-select-sm">
                                <option value="light" selected="@(theme == "light")">@Localizer["LightTheme"]</option>
                                <option value="dark" selected="@(theme == "dark")">@Localizer["DarkTheme"]</option>
                            </select>
                        </form>

                        <form method="post" action="/Localization/SetLanguage">
                            <select name="culture" onchange="this.form.submit()" class="form-select form-select-sm">
                                <option value="ru" selected="@(culture == "ru")">Русский</option>
                                <option value="en" selected="@(culture == "en")">English</option>
                            </select>
                        </form>
                        <form class="d-flex" method="get" action="/Search">
                            <input class="form-control me-2" type="search" name="q" placeholder="Поиск..." />
                            <button class="btn btn-outline-light" type="submit">Найти</button>
                        </form>

                        <partial name="_LoginPartial" />
                    </div>

                </div>
            </div>
        </nav>
    </header>
    <a href="#" id="open-support-ticket" class="text-muted small">
        Create support ticket
    </a>
    <div class="modal fade" id="supportTicketModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Create Support Ticket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label">Summary</label>
                        <textarea id="ticket-summary" class="form-control"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Priority</label>
                        <select id="ticket-priority" class="form-select">
                            <option>High</option>
                            <option>Average</option>
                            <option>Low</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Admin emails (comma separated)</label>
                        <input id="ticket-admins" class="form-control" placeholder="admin@example.com" />
                    </div>

                    <input type="hidden" id="ticket-link" />
                    <input type="hidden" id="ticket-inventory" />

                </div>

                <div class="modal-footer">
                    <button id="submit-ticket" class="btn btn-primary">Submit</button>
                </div>

            </div>
        </div>
    </div>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - InventoryManagerApp
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="@Html.Raw("https://cdn.jsdelivr.net/npm/@yaireo/tagify")"></script>
    <script>
        document.getElementById("open-support-ticket").addEventListener("click", function () {
            document.getElementById("ticket-link").value = window.location.href;

            // Если на странице есть InventoryId — добавим
            const invTitle = document.getElementById("inv-title");
            document.getElementById("ticket-inventory").value = invTitle ? invTitle.value : "";

            new bootstrap.Modal(document.getElementById("supportTicketModal")).show();
        });

        document.getElementById("submit-ticket").addEventListener("click", function () {

            const data = {
                reportedBy: "@User.Identity.Name",
                inventory: document.getElementById("ticket-inventory").value,
                link: document.getElementById("ticket-link").value,
                priority: document.getElementById("ticket-priority").value,
                summary: document.getElementById("ticket-summary").value,
                admins: document.getElementById("ticket-admins").value.split(",").map(x => x.trim())
            };

            fetch("/Support/UploadTicketToOneDrive", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": document.querySelector("input[name='__RequestVerificationToken']").value
                },
                body: JSON.stringify(data)
            })
            .then(async r => {
                let text = await r.text();
                try {
                    return JSON.parse(text);
                } catch {
                return { ok: false, raw: text };
            }
        })

            .then(r => {
                alert("Ticket uploaded to OneDrive!");
                location.reload();
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
