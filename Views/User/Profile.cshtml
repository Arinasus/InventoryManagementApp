@using InventoryManagementApp.Models
@model UserProfileViewModel

<div class="container mt-4">

    <h2 class="mb-4">Личная страница: @Model.UserName</h2>
        <a href="/User/Salesforce" class="btn btn-primary mb-4">
            Integrate with Salesforce
        </a>

    <form method="get" class="mb-4">
        <input type="text" name="search" value="@Model.SearchQuery"
               class="form-control" placeholder="Поиск по книгам..." />
    </form>

    <h3 class="mb-3">Мои инвентарные книги</h3>

    <a href="/Inventory/Create" class="btn btn-primary mb-3">Создать инвентарную книгу</a>
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>
                    <a href="?sortOrder=@(Model.SortOrder == "title_asc" ? "title_desc" : "title_asc")"
                       class="text-white text-decoration-none">Название</a>
                </th>
                <th>Описание</th>
                <th>
                    <a href="?sortOrder=@(Model.SortOrder == "items_asc" ? "items_desc" : "items_asc")"
                       class="text-white text-decoration-none">Предметов</a>
                </th>
                <th>Создано</th>
                <th class="text-end"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var inv in Model.OwnedInventories)
            {
                <tr class="inv-row" onclick="location.href='/Inventory/Details/@inv.Id'" style="cursor:pointer;">
                    <td>@inv.Title</td>
                    <td>@inv.Description</td>
                    <td>@inv.ItemsCount</td>
                    <td>@inv.CreatedAt.ToShortDateString()</td>
                    <td class="text-end">
                        <div class="actions" style="display:none;">
                            <a href="/Inventory/Delete/@inv.Id" class="text-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h3 class="mt-5 mb-3">Книги, к которым у меня есть доступ</h3>

    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Название</th>
                <th>Описание</th>
                <th>Создатель</th>
                <th>Предметов</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var inv in Model.AccessibleInventories)
            {
                <tr onclick="location.href='/Inventory/Details/@inv.Id'" style="cursor:pointer;">
                    <td>@inv.Title</td>
                    <td>@inv.Description</td>
                    <td>@inv.CreatorName</td>
                    <td>@inv.ItemsCount</td>
                </tr>
            }
        </tbody>
    </table>

</div>
<script>
    document.querySelectorAll(".inv-row").forEach(row => {
        row.addEventListener("mouseenter", () => {
            row.querySelector(".actions").style.display = "inline-block";
        });
        row.addEventListener("mouseleave", () => {
            row.querySelector(".actions").style.display = "none";
        });
    });
</script>
