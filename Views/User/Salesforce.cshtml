@using InventoryManagementApp.ViewModels
@model SalesforceViewModel

<h2>Salesforce Integration</h2>

<form method="post" asp-antiforgery="false">
    <div class="mb-3">
        <label>Company Name</label>
        <input class="form-control" asp-for="CompanyName" />
    </div>

    <div class="mb-3">
        <label>Phone</label>
        <input class="form-control" asp-for="Phone" />
    </div>

    <div class="mb-3">
        <label>Website</label>
        <input class="form-control" asp-for="Website" />
    </div>

    <div class="mb-3">
        <label>Industry</label>
        <input class="form-control" asp-for="Industry" />
    </div>

    <div class="mb-3">
        <label>Description</label>
        <textarea class="form-control" asp-for="Description"></textarea>
    </div>

    <button class="btn btn-success">Send to Salesforce</button>
</form>
